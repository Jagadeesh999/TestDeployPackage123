<?xml version="1.0" encoding="UTF-8"?>
<!--
    ProjectAutomator Deployment Descriptor - WmDeployer (IS 11.x)
    Root element: DeployerSpec

    Placeholders substituted at runtime by Prepare-ProjectAutomator.ps1:
      @@SOURCE_HOST@@      - IS host (e.g. localhost)
      @@SOURCE_PORT@@      - IS port (e.g. 5555)
      @@SOURCE_USER@@      - IS admin username
      @@SOURCE_PASSWORD@@  - IS admin password
      @@TARGET_HOST@@      - Target IS host
      @@TARGET_PORT@@      - Target IS port
      @@TARGET_USER@@      - Target IS admin username
      @@TARGET_PASSWORD@@  - Target IS admin password
      @@PACKAGE_NAME@@     - Package name (e.g. TestDeployPackage)
      @@DIST_DIR@@         - ABE output directory containing the composite ZIP
-->
<DeployerSpec exitOnError="true" sourceType="Repository">

    <DeployerServer>
        <host>localhost:5555</host>
        <user>Administrator</user>
        <pwd>{AES}Y5IgMqjfvkgbg7p5VUZztw==</pwd>
        <port>5555</port>
    </DeployerServer>

    <Environment>
        <IS>
            <isalias name="RepoISTarget">
                <host>localhost</host>
                <port>5555</port>
                <user>Administrator</user>
                <pwd>{AES}Y5IgMqjfvkgbg7p5VUZztw==</pwd>
                <port>5555</port>
                <useSSL>false</useSSL>
                <installDeployerResource>true</installDeployerResource>
                <Test>false</Test>
            </isalias>
            <isalias name="RepoISTargetForLogicalServer">
                <host>localhost</host>
                <port>5555</port>
                <user>Administrator</user>
                <pwd>{AES}Y5IgMqjfvkgbg7p5VUZztw==</pwd>
                <port>5555</port>
                <useSSL>false</useSSL>
                <installDeployerResource>true</installDeployerResource>
                <Test>false</Test>
            </isalias>
        </IS>

        <Repository>
            <repalias name="ABESource">
                <type>FlatFile</type>
                <urlOrDirectory>@@DIST_DIR@@</urlOrDirectory>
                <Test>true</Test>
            </repalias>
        </Repository>
    </Environment>

    <Projects projectPrefix="ACDL_">
        <Project name="ACDL_@@PACKAGE_NAME@@" overwrite="true" type="Repository" ignoreMissingDependencies="true">

            <DeploymentSet name="myDeploymentSet" autoResolve="full" srcAlias="ABESource">
                <Composite name="@@PACKAGE_NAME@@" srcAlias="ABESource" type="IS"/>
            </DeploymentSet>

            <DeploymentMap name="myDeploymentMap"/>

            <MapSetMapping mapName="myDeploymentMap" setName="myDeploymentSet">
                <alias type="IS">TargetIS</alias>
                <alias logicalServer="Default" type="IS">TargetISLogical</alias>
            </MapSetMapping>

            <DeploymentCandidate name="myDeployment" mapName="myDeploymentMap"/>
        </Project>
    </Projects>

</DeployerSpec>