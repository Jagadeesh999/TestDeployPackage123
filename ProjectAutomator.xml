<?xml version="1.0" encoding="UTF-8"?>
<DeployerSpec>
    <!-- 1. Deployer Server Connection (Port goes inside host) -->
    <DeployerServer>
        <host>localhost:5555</host>
        <user>Administrator</user>
        <pwd>manage</pwd>
    </DeployerServer>

    <Environment>
        <!-- 2. Source Repository Definition -->
        <Repository>
            <repalias name="ABE_Repo">
                <path>C:\SoftwareAG11\ABE_Output</path>
            </repalias>
        </Repository>

        <!-- 3. Target Server Definition (Port goes inside host here too) -->
        <IS>
            <isalias name="Local_Target_IS">
                <host>localhost:5555</host>
                <user>Administrator</user>
                <pwd>manage</pwd>
                <useSSL>false</useSSL>
                <installFolder>C:\SoftwareAG11\IntegrationServer</installFolder>
            </isalias>
        </IS>
    </Environment>

    <!-- 4. Project Definition -->
    <Project name="TestDeployProject" overwrite="true">
        <DeploymentSet name="MyPackageSet" autoResolve="full">
            <Repository name="ABE_Repo"/>
            <Component type="IS" name="TestDeployPackage"/>
        </DeploymentSet>

        <DeploymentMap name="MyDeploymentMap">
            <MapSet name="MyPackageSet" target="Local_Target_IS"/>
        </DeploymentMap>

        <DeploymentCandidate name="MyCandidate" map="MyDeploymentMap"/>
    </Project>
</DeployerSpec>
