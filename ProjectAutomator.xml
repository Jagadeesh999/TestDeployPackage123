<?xml version="1.0" encoding="UTF-8"?>
<DeployerSpec exitOnError="true" sourceType="Repository">
    <DeployerServer>
        <host>localhost:5555</host>
        <user>Administrator</user>
        <pwd>manage</pwd>
    </DeployerServer>

    <Environment>
        <IS>
            <isalias name="LocalTargetIS">
                <host>localhost</host>
                <port>5555</port>
                <user>Administrator</user>
                <pwd>manage</pwd>
                <useSSL>false</useSSL>
                <installDeployerResource>true</installDeployerResource>
                <Test>true</Test>
            </isalias>
        </IS>
        <Repository>
            <repalias name="ABE_Repo">
                <type>FlatFile</type>
                <!-- Path where ABE generates the build -->
                <urlOrDirectory>C:\SoftwareAG11\ABE_Output</urlOrDirectory>
                <Test>true</Test>
            </repalias>
        </Repository>
    </Environment>

    <Projects projectPrefix="CI_">
        <Project name="TestDeployProject" overwrite="true" type="Repository" ignoreMissingDependencies="true">
            <DeploymentSet name="MyPackageSet" autoResolve="full" srcAlias="ABE_Repo">
                <!-- For IS Packages, we use the Composite tag -->
                <Composite name="TestDeployPackage" srcAlias="ABE_Repo" type="IS"/>
            </DeploymentSet>
            
            <DeploymentMap name="MyMap"/>
            
            <MapSetMapping mapName="MyMap" setName="MyPackageSet">
                <alias type="IS">LocalTargetIS</alias>
            </MapSetMapping>
            
            <DeploymentCandidate name="MyCandidate" mapName="MyMap"/>
        </Project>
    </Projects>
</DeployerSpec>
